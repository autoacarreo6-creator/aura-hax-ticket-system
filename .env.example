# Configuración del Bot
DISCORD_TOKEN=tu_token_del_bot_aqui
OWNER_ID=tu_id_de_discord_aqui
GUILD_ID=id_del_servidor_aqui

# KeyAuth (opcional - para generar keys automáticamente)
# Si no configuras esto, el bot generará keys temporales random
KEYAUTH_NAME=nombre_de_tu_app_en_keyauth
KEYAUTH_OWNERID=tu_owner_id_de_keyauth
KEYAUTH_SECRET=tu_secret_key_de_keyauth

# Información de Pago (opcional - para mostrar en los mensajes)
# Binance
BINANCE_ADDRESS=tu_direccion_usdt_bep20

# Nequi
NEQUI_NUMBER=312345678
NEQUI_NAME=Tu Nombre

# PayPal
PAYPAL_EMAIL=tu@email.com
